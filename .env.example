# Copy this file to .env and fill in the values

# Required: Anthropic API key for AI categorization and insights
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default database location (default: backend/cut_the_fat.db)
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/cut_the_fat.db

# Optional: GitHub token for bug reports from the desktop app
# GITHUB_TOKEN=ghp_...

# ── Desktop-App Updater (nur für eigene Fork-Builds) ──────────────────────────
# Wenn du die App aus deinem eigenen Fork baust und den Auto-Updater nutzen
# willst, trage hier deinen eigenen Minisign Public Key und Release-Endpoint ein.
# Anleitung: doc/tauri-desktop.md#eigener-fork
#
# Generieren: npx @tauri-apps/cli signer generate
# TAURI_UPDATER_PUBKEY=
# TAURI_UPDATER_ENDPOINT=https://github.com/DEIN-USER/cut-the-fat/releases/latest/download/latest.json
